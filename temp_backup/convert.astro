---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="图片格式转换 | AI 项目 | Portfolio"
  description="免费在线图片格式转换工具，批量将 PNG、WEBP、BMP 等格式转换为 JPG、PNG �?WebP�?
  keywords="图片格式转换, 在线转换, PNG转JPG, WebP转JPG, BMP转JPG, 批量转换"
>

<div class="site-container mx-auto py-12 md:py-20">
  <div class="relative z-20 mx-auto mb-12 text-center md:mb-16">
    <h1 class="font-sans text-4xl font-bold tracking-normal text-neutral-900 dark:text-white sm:text-5xl">
      图片<span class="text-primary dark:text-primary-light">格式转换</span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-neutral-700 dark:text-neutral-300 sm:mt-4 sm:text-base lg:text-lg">
      批量�?PNG、WEBP、BMP、TIFF 等格式转换为 JPG 格式。纯浏览器端处理，安全快速�?    </p>
  </div>

  <!-- Control Bar -->
  <div class="mb-5 flex flex-wrap items-center gap-3 rounded-xl border border-neutral-200 bg-white/80 px-5 py-3 dark:border-neutral-700 dark:bg-neutral-900/80">
    <div class="flex items-center gap-2">
      <span class="whitespace-nowrap text-xs font-medium text-neutral-500 dark:text-neutral-400">转换�?/span>
      <select id="formatSelect" class="rounded-lg border border-neutral-200 bg-white px-2.5 py-1.5 text-xs font-medium text-neutral-700 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-200">
        <option value="image/jpeg" selected>JPG</option>
        <option value="image/png">PNG</option>
        <option value="image/webp">WebP</option>
      </select>
    </div>
    <span class="hidden h-5 w-px bg-neutral-200 dark:bg-neutral-700 sm:block"></span>
    <div class="flex items-center gap-2">
      <span class="whitespace-nowrap text-xs font-medium text-neutral-500 dark:text-neutral-400">画质</span>
      <input id="qualitySlider" type="range" min="10" max="100" value="92" class="h-1.5 w-24 accent-primary" />
      <span id="qualityLabel" class="w-8 text-xs font-semibold text-neutral-700 dark:text-neutral-200">92%</span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button id="convertBtn" class="rounded-xl bg-primary px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition-all hover:bg-primary-strong hover:shadow-xl hover:shadow-primary/30 active:scale-95 dark:bg-primary-dark dark:shadow-primary/15 dark:hover:bg-primary">开始转�?/button>
      <button id="clearBtn" class="rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm font-medium text-neutral-500 transition-all hover:border-red-300 hover:text-red-500 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:border-red-600 dark:hover:text-red-400">清空</button>
    </div>
  </div>

  <!-- Upload Zone -->
  <div id="dropZone" class="flex w-full cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-neutral-300 bg-white/60 px-6 py-16 transition-all duration-300 hover:border-primary/50 hover:bg-primary/[0.02] dark:border-neutral-600 dark:bg-neutral-900/50 dark:hover:border-primary/40 dark:hover:bg-primary/[0.03] md:py-20">
    <div class="mb-5 flex h-18 w-18 items-center justify-center rounded-2xl bg-primary/10 dark:bg-primary/20">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary dark:text-primary-light"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    </div>
    <p class="text-base font-medium text-neutral-700 dark:text-neutral-200 sm:text-lg">拖拽图片到此处，�?span class="text-primary dark:text-primary-light">点击上传</span></p>
    <p class="mt-2 text-xs text-neutral-400 dark:text-neutral-500 sm:text-sm">Ctrl+V 粘贴图片 �?支持 JPG / PNG / WebP / BMP / TIFF �?一次最�?50 �?/p>
    <input id="fileInput" type="file" accept="image/*" multiple class="hidden" />
  </div>

  <div id="previewArea" class="mx-auto mt-5 hidden max-w-4xl"><div class="mb-3 flex items-center justify-between"><span id="previewCount" class="text-sm font-medium text-neutral-600 dark:text-neutral-300"></span><button id="clearPreviewBtn" class="text-xs text-neutral-400 transition-colors hover:text-red-500 dark:text-neutral-500 dark:hover:text-red-400">清空全部</button></div><div id="previewGrid" class="flex flex-wrap gap-2"></div></div>
  <div id="progressBar" class="mx-auto mt-5 hidden max-w-md"><div class="overflow-hidden rounded-full bg-neutral-200 dark:bg-neutral-700"><div id="progressFill" class="h-2 rounded-full bg-primary transition-all duration-300 dark:bg-primary-dark" style="width:0%"></div></div><p id="progressText" class="mt-1 text-center text-xs text-neutral-400 dark:text-neutral-500">准备�?..</p></div>
  <div id="results" class="mx-auto mt-8 hidden max-w-5xl"><div id="summaryBar" class="mb-6 flex flex-wrap items-center gap-3 rounded-xl border border-green-200 bg-green-50/80 px-5 py-3 dark:border-green-800 dark:bg-green-950/50"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-600 dark:text-green-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span id="summaryText" class="text-sm font-medium text-green-700 dark:text-green-300"></span><button id="downloadAllBtn" class="ml-auto rounded-lg bg-primary px-5 py-2 text-sm font-semibold text-white transition-all hover:bg-primary-strong active:scale-95 dark:bg-primary-dark dark:hover:bg-primary">📦 批量下载</button></div><div id="imageGrid" class="grid gap-3" style="grid-template-columns:repeat(auto-fill,minmax(220px,300px))"></div></div>
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4" onclick="this.classList.add('hidden');this.classList.remove('flex')"><button class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-2xl text-white transition-colors hover:bg-white/40" onclick="document.getElementById('lightbox')!.classList.add('hidden');document.getElementById('lightbox')!.classList.remove('flex')">&times;</button><img id="lightboxImg" src="" alt="预览" class="max-h-[90vh] max-w-full rounded-xl object-contain shadow-2xl" onclick="event.stopPropagation()" /></div>

  <!-- Features + FAQ -->
  <div class="mx-auto max-w-4xl">

  <!-- Features -->
  <div class="mt-20">
    <h2 class="mb-10 text-center font-sans text-3xl font-bold tracking-normal text-neutral-900 dark:text-white sm:text-4xl">全格式覆�?· 一键转�?/h2>
    <div class="grid gap-8 sm:grid-cols-2">
      <div class="flex gap-4">
        <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-2xl dark:bg-blue-950">🔄</div>
        <div>
          <h3 class="mb-1 text-sm font-semibold text-neutral-800 dark:text-neutral-200">多格式输�?/h3>
          <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">支持 JPG、PNG、WebP、BMP、TIFF 等常见格式�?/p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-green-50 text-2xl dark:bg-green-950">�?/div>
        <div>
          <h3 class="mb-1 text-sm font-semibold text-neutral-800 dark:text-neutral-200">批量转换</h3>
          <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">一次拖入多张图片，批量完成格式转换�?/p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-purple-50 text-2xl dark:bg-purple-950">🔒</div>
        <div>
          <h3 class="mb-1 text-sm font-semibold text-neutral-800 dark:text-neutral-200">隐私安全</h3>
          <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">纯浏览器端处理，图片不会上传到任何服务器�?/p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-orange-50 text-2xl dark:bg-orange-950">🎨</div>
        <div>
          <h3 class="mb-1 text-sm font-semibold text-neutral-800 dark:text-neutral-200">质量可控</h3>
          <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">自由调节输出画质，平衡文件大小和视觉效果�?/p>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-16 max-w-2xl pb-16"><h2 class="mb-8 text-center font-sans text-2xl font-bold text-neutral-900 dark:text-white sm:text-3xl" data-i18n="convert-faq">常见问题</h2>
    <div class="mx-auto max-w-2xl space-y-6">
      <div>
        <h3 class="mb-1.5 text-sm font-semibold text-neutral-800 dark:text-neutral-200" data-i18n="convert-faq-q1">可以�?PNG 透明图转�?JPG 吗？</h3>
        <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">可以。转换时透明区域会自动填充为白色背景�?/p>
      </div>
      <div>
        <h3 class="mb-1.5 text-sm font-semibold text-neutral-800 dark:text-neutral-200">支持哪些输入格式�?/h3>
        <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">输入支持 JPG、PNG、GIF、WebP、BMP、TIFF 等浏览器可识别的图片格式�?/p>
      </div>
    </div>
  </div>

</div>

</Layout>

<script>
  const state = { files: [] as File[], results: [] as any[], converting: false };
  const el = (id: string) => document.getElementById(id)!;
  const dropZone = el('dropZone');
  const fileInput = el('fileInput') as HTMLInputElement;
  const previewArea = el('previewArea'), previewGrid = el('previewGrid'), previewCount = el('previewCount');
  const progressBar = el('progressBar'), progressFill = el('progressFill'), progressText = el('progressText');
  const results = el('results'), summaryBar = el('summaryBar'), summaryText = el('summaryText'), imageGrid = el('imageGrid');
  const convertBtn = el('convertBtn'), clearBtn = el('clearBtn'), downloadAllBtn = el('downloadAllBtn');
  const qualitySlider = el('qualitySlider') as HTMLInputElement, qualityLabel = el('qualityLabel');
  const formatSelect = el('formatSelect') as HTMLSelectElement;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary','bg-primary/[0.05]'); });
  dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('border-primary','bg-primary/[0.05]'); });
  dropZone.addEventListener('drop', (e) => { e.preventDefault(); dropZone.classList.remove('border-primary','bg-primary/[0.05]'); if (e.dataTransfer?.files) addFiles(e.dataTransfer.files); });
  fileInput.addEventListener('change', () => { if (fileInput.files) addFiles(fileInput.files); });
  document.addEventListener('paste', (e) => { if (e.clipboardData?.files.length) { e.preventDefault(); addFiles(e.clipboardData.files); } });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { const lb = document.getElementById('lightbox')!; lb.classList.add('hidden'); lb.classList.remove('flex'); } });
  qualitySlider.addEventListener('input', () => { qualityLabel.textContent = qualitySlider.value + '%'; });
  convertBtn.addEventListener('click', () => convertAll());
  clearBtn.addEventListener('click', () => resetAll());
  el('clearPreviewBtn').addEventListener('click', () => resetAll());

  function addFiles(fileList: FileList) {
    if (state.converting) return;
    const nf = Array.from(fileList).filter(f => f.type.startsWith('image/'));
    if (state.files.length + nf.length > 50) { alert('一次最�?50 �?); return; }
    state.files.push(...nf);
    results.classList.add('hidden'); state.results = [];
    previewArea.classList.remove('hidden');
    previewCount.textContent = `已选择 ${state.files.length} 张图片`;
    previewGrid.innerHTML = '';
    state.files.forEach((f, i) => { const u = URL.createObjectURL(f); const c = document.createElement('div'); c.className = 'relative group inline-flex items-center gap-2 rounded-lg border border-neutral-200 bg-white/80 px-3 py-2 text-xs dark:border-neutral-700 dark:bg-neutral-800/80'; c.innerHTML = `<img src="${u}" alt="" class="h-8 w-8 rounded object-cover"/><span class="max-w-[100px] truncate text-neutral-600 dark:text-neutral-300">${f.name}</span><span class="text-neutral-400 dark:text-neutral-500">${(f.size/1000).toFixed(0)}KB</span><button class="ml-1 flex h-4 w-4 items-center justify-center rounded-full bg-neutral-300 text-[10px] leading-none text-white hover:bg-red-400 dark:bg-neutral-600 dark:hover:bg-red-500" data-rm="${i}">&times;</button>`; previewGrid.appendChild(c); });
    previewGrid.querySelectorAll('[data-rm]').forEach(b => { b.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); const i = parseInt((b as HTMLElement).dataset.rm!); state.files.splice(i,1); state.files.length === 0 ? resetAll() : addFiles(new DataTransfer().files); resetAll(); state.files.forEach((f,j)=>{const u2=URL.createObjectURL(f);previewGrid.innerHTML='';state.files.forEach((ff,jj)=>{const u3=URL.createObjectURL(ff);const cc=document.createElement('div');cc.className='relative group inline-flex items-center gap-2 rounded-lg border border-neutral-200 bg-white/80 px-3 py-2 text-xs dark:border-neutral-700 dark:bg-neutral-800/80';cc.innerHTML=`<img src="${u3}" alt="" class="h-8 w-8 rounded object-cover"/><span class="max-w-[100px] truncate text-neutral-600 dark:text-neutral-300">${ff.name}</span><span class="text-neutral-400 dark:text-neutral-500">${(ff.size/1000).toFixed(0)}KB</span><button class="ml-1 flex h-4 w-4 items-center justify-center rounded-full bg-neutral-300 text-[10px] leading-none text-white hover:bg-red-400 dark:bg-neutral-600 dark:hover:bg-red-500" data-rm="${jj}">&times;</button>`;previewGrid.appendChild(cc);});return;})});});
  }

  function resetAll() { state.files = []; state.results = []; state.converting = false; previewArea.classList.add('hidden'); previewGrid.innerHTML = ''; progressBar.classList.add('hidden'); results.classList.add('hidden'); fileInput.value = ''; progressFill.style.width = '0%'; progressText.textContent = '准备�?..'; }

  async function convertAll() {
    if (state.files.length === 0 || state.converting) return;
    state.converting = true; state.results = []; results.classList.remove('hidden'); summaryBar.classList.add('hidden'); progressBar.classList.remove('hidden'); imageGrid.innerHTML = '';
    convertBtn.setAttribute('disabled','true'); convertBtn.textContent = '转换�?..';
    const quality = parseInt(qualitySlider.value) / 100, format = formatSelect.value;
    let totalO = 0, totalC = 0;
    for (let i = 0; i < state.files.length; i++) {
      progressFill.style.width = ((i / state.files.length) * 100) + '%';
      progressText.textContent = `正在转换 ${i+1}/${state.files.length}�?{state.files[i].name}`;
      const r = await convert(state.files[i], quality, format);
      if (r) { state.results.push(r); totalO += r.os; totalC += r.cs; appendCard(r, i); }
    }
    const pct = totalO > 0 ? ((1 - totalC / totalO) * 100).toFixed(1) : '0';
    summaryText.textContent = `共转�?${state.results.length} 张图片` + (pct !== '0' ? `，体积变�?${(totalC>totalO?'+':'')}${((totalC-totalO)/1000).toFixed(1)}KB` : '');
    summaryBar.classList.remove('hidden'); progressFill.style.width = '100%'; progressText.textContent = '完成�?;
    setTimeout(() => progressBar.classList.add('hidden'), 2500);
    state.converting = false; convertBtn.removeAttribute('disabled'); convertBtn.textContent = '开始转�?;
  }

  function convert(file: File, quality: number, format: string): Promise<any> {
    return new Promise(r => {
      const u = URL.createObjectURL(file); const img = new Image();
      img.onload = () => { URL.revokeObjectURL(u); const c = document.createElement('canvas'); c.width = img.naturalWidth; c.height = img.naturalHeight; c.getContext('2d')!.drawImage(img, 0, 0);
        c.toBlob(b => { if (!b) { r(null); return; }
          const cu = URL.createObjectURL(b);
          r({ name: getOutName(file.name, format), os: file.size, cs: b.size, ou: URL.createObjectURL(file), cu, w: img.naturalWidth, h: img.naturalHeight });
        }, format, quality);
      };
      img.onerror = () => { URL.revokeObjectURL(u); r(null); };
      img.src = u;
    });
  }

  function appendCard(d: any, i: number) {
    const pct = d.os > 0 ? ((1 - d.cs / d.os) * 100).toFixed(1) : '0';
    const origKB = (d.os / 1000).toFixed(1);
    const compKB = (d.cs / 1000).toFixed(1);
    const grew = d.cs > d.os;
    const arrow = grew
      ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block text-red-500"><polyline points="18 15 12 9 6 15"/></svg>'
      : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block text-green-500"><polyline points="6 9 12 15 18 9"/></svg>';
    const pctColor = grew ? 'text-red-600 bg-red-100 dark:bg-red-900/40 dark:text-red-400' : 'text-emerald-600 bg-emerald-100 dark:bg-emerald-900/40 dark:text-emerald-400';
    const pctSign = grew ? '+' : (parseFloat(pct) > 0 ? '-' : '');
    const c = document.createElement('div');
    c.className = 'result-card group rounded-2xl bg-white/80 shadow-sm transition-all hover:shadow-md dark:bg-neutral-900/80 overflow-hidden';
    c.setAttribute('data-index', String(i));
    c.innerHTML = `<div class="relative aspect-square cursor-pointer overflow-hidden bg-neutral-100 dark:bg-neutral-800"><img src="${d.cu}" alt="${d.name}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"/><div class="fold-corner absolute right-0 top-0 z-10 h-0 w-0 cursor-pointer transition-colors duration-200" style="border-style:solid;border-width:0 28px 28px 0;border-color:transparent #22c55e transparent transparent" data-remove-result="${i}"><span class="fold-icon pointer-events-none absolute text-[10px] font-bold leading-none text-white" style="top:3px;right:-24px">�?/span></div></div><div class="px-2 py-1.5"><p class="truncate text-[11px] font-medium text-neutral-700 dark:text-neutral-200" title="${d.name}">${d.name}</p><div class="mt-0.5 flex items-center justify-between gap-1 text-[10px]"><div class="flex min-w-0 items-center gap-1"><span class="text-neutral-400 dark:text-neutral-500">${origKB}KB</span>${arrow}<span class="font-semibold text-neutral-700 dark:text-neutral-300">${compKB}KB</span><span class="rounded-full px-1 py-0.5 text-[9px] font-semibold ${pctColor}">${pctSign}${Math.abs(parseFloat(pct))}%</span></div><button class="download-single flex-shrink-0 rounded p-0.5 text-neutral-400 transition-colors hover:text-emerald-600 hover:bg-emerald-50 dark:text-neutral-500 dark:hover:text-emerald-400 dark:hover:bg-emerald-900/40" title="下载" data-url="${d.cu}" data-name="${d.name}"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button></div></div>`;
    imageGrid.appendChild(c);
    c.querySelector('img')!.addEventListener('click', (e) => { e.stopPropagation(); const lb = document.getElementById('lightbox')!; (document.getElementById('lightboxImg') as HTMLImageElement).src = d.cu; lb.classList.remove('hidden'); lb.classList.add('flex'); });
    const fold = c.querySelector('.fold-corner') as HTMLElement;
    const foldIcon = fold.querySelector('.fold-icon') as HTMLElement;
    fold.addEventListener('mouseenter', () => { fold.style.borderColor = 'transparent #ef4444 transparent transparent'; foldIcon.textContent = '�?; foldIcon.style.fontSize = '11px'; });
    fold.addEventListener('mouseleave', () => { fold.style.borderColor = 'transparent #22c55e transparent transparent'; foldIcon.textContent = '�?; foldIcon.style.fontSize = ''; });
    fold.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); const idx = parseInt(fold.dataset.removeResult!); state.results.splice(idx, 1); c.remove(); imageGrid.querySelectorAll('.result-card').forEach((c2, i2) => { (c2 as HTMLElement).setAttribute('data-index', String(i2)); const fc = c2.querySelector('.fold-corner') as HTMLElement; if (fc) fc.setAttribute('data-remove-result', String(i2)); }); if (state.results.length === 0) { summaryBar.classList.add('hidden'); imageGrid.innerHTML = ''; } });
    const dl = c.querySelector('.download-single') as HTMLElement; if (dl) { dl.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); download(dl.dataset.url!, dl.dataset.name!); }); }
  }

  function getOutName(n: string, f: string): string { const b = n.substring(0, n.lastIndexOf('.')) || n; if (f === 'image/jpeg') return b + '.jpg'; if (f === 'image/webp') return b + '.webp'; return b + '.png'; }
  function download(u: string, n: string) { const a = document.createElement('a'); a.href = u; a.download = n; document.body.appendChild(a); a.click(); document.body.removeChild(a); }

  downloadAllBtn.addEventListener('click', async () => {
    if (state.results.length === 0) return;
    downloadAllBtn.textContent = '�?打包�?..'; downloadAllBtn.setAttribute('disabled','true');
    try { const z = await loadJSZip(); const zip = new z(); for (const r of state.results) { const b = await fetch(r.cu).then(x => x.blob()); zip.file(r.name, b); } const zb = await zip.generateAsync({ type: 'blob' }); download(URL.createObjectURL(zb), 'converted-images.zip'); } catch (e) { alert(__t('批量下载失败')); }
    downloadAllBtn.textContent = __t('📦 批量下载'); downloadAllBtn.removeAttribute('disabled');
  });

  function loadJSZip(): Promise<any> {
    return new Promise((res, rej) => {
      if (typeof (window as any).JSZip !== 'undefined') { res((window as any).JSZip); return; }
      const s = document.createElement('script'); s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
      s.onload = () => { if (typeof (window as any).JSZip !== 'undefined') res((window as any).JSZip); else rej(new Error('JSZip failed')); };
      s.onerror = rej; document.head.appendChild(s);
    });
  }
</script>
<style>#qualitySlider{appearance:none;height:6px;border-radius:3px;background:#dfe4ed;outline:none}.dark #qualitySlider{background:#2c3542}#qualitySlider::-webkit-slider-thumb{appearance:none;width:16px;height:16px;border-radius:50%;background:#2d6dc3;cursor:pointer;transition:transform .15s}#qualitySlider::-webkit-slider-thumb:hover{transform:scale(1.2)}</style>
