---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="AI工具 / AI Tools">
  <div class="site-container mx-auto py-16 md:py-24">
    <div class="text-center mb-12">
      <h1 class="font-sans text-4xl font-bold tracking-normal text-neutral-900 dark:text-white sm:text-5xl">
        AI<span class="text-primary dark:text-primary-light" data-i18n="tool-page-title">辅助创建的工具</span>
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-base text-neutral-600 dark:text-neutral-400">
        AI 辅助开发的实用工具，本地处理，即开即用
      </p>
    </div>

    <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 max-w-6xl mx-auto">

      <!-- 图片压缩 -->
      <div class="group flex flex-col items-center text-center rounded-2xl border border-neutral-200 bg-white/80 p-6 sm:p-7 transition-all duration-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/30">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 dark:bg-blue-950 mb-4">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-blue-600 dark:text-blue-400"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200 mb-1.5">图片压缩</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed mb-4">智能压缩引擎，自动优化体积<br/>支持 JPG / PNG / WebP 格式</p>
        <a href="/tools/compress" class="mt-auto w-1/2 text-center px-3 py-2 text-xs font-medium rounded-lg bg-primary text-white hover:bg-primary/90 transition-colors shadow-sm">
          立即使用
        </a>
      </div>

      <!-- 格式转换 -->
      <div class="group flex flex-col items-center text-center rounded-2xl border border-neutral-200 bg-white/80 p-6 sm:p-7 transition-all duration-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/30">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-green-50 dark:bg-green-950 mb-4">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-green-600 dark:text-green-400"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200 mb-1.5">格式转换</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed mb-4">JPG / PNG / WebP / BMP 互转<br/>纯浏览器端处理，极速转换</p>
        <a href="/tools/convert" class="mt-auto w-1/2 text-center px-3 py-2 text-xs font-medium rounded-lg bg-primary text-white hover:bg-primary/90 transition-colors shadow-sm">
          立即使用
        </a>
      </div>

      <!-- 尺寸调整 -->
      <div class="group flex flex-col items-center text-center rounded-2xl border border-neutral-200 bg-white/80 p-6 sm:p-7 transition-all duration-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/30">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-50 dark:bg-purple-950 mb-4">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-purple-600 dark:text-purple-400"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
        </div>
        <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200 mb-1.5">尺寸调整</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed mb-4">批量调整图片尺寸<br/>支持 4K / 2K / 1080p 预设</p>
        <a href="/tools/resize" class="mt-auto w-1/2 text-center px-3 py-2 text-xs font-medium rounded-lg bg-primary text-white hover:bg-primary/90 transition-colors shadow-sm">
          立即使用
        </a>
      </div>

      <!-- FrameGrab -->
      <div class="group flex flex-col items-center text-center rounded-2xl border border-neutral-200 bg-white/80 p-6 sm:p-7 transition-all duration-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/30">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white dark:bg-neutral-800 mb-4 p-1.5">
          <img src="/assets/framegrab-logo.png" alt="FrameGrab" class="w-full h-full object-contain" />
        </div>
        <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200 mb-1.5">FrameGrab</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed mb-4">右键视频导出首/末帧 JPG<br/>AI 辅助开发，本地运行</p>
        <div class="flex gap-2 w-full mt-auto">
          <a href="https://github.com/SJ3199/FrameGrab" target="_blank" rel="noopener noreferrer" class="flex-1 text-center px-2 py-2 text-xs font-medium rounded-lg bg-primary text-white hover:bg-primary/90 transition-colors shadow-sm">
            项目主页
          </a>
          <a href="https://github.com/SJ3199/FrameGrab/raw/master/FrameGrab-v3.0-Setup.exe" download class="flex-1 text-center px-2 py-2 text-xs font-medium rounded-lg bg-primary text-white hover:bg-primary/90 transition-colors shadow-sm">
            下载安装
          </a>
        </div>
      </div>

    </div>
  </div>
</Layout>
