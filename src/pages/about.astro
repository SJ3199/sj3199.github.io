---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="AI工具 / AI Tools">
  <div class="site-container mx-auto py-16 md:py-24">
    <div class="text-center mb-12">
      <h1 class="font-sans text-4xl font-bold tracking-normal text-neutral-900 dark:text-white sm:text-5xl">
        AI<span class="text-primary dark:text-primary-light" data-i18n="tool-page-title">辅助创建的工具</span>
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-base text-neutral-600 dark:text-neutral-400" data-i18n="tool-page-desc">
        基于浏览器本地处理的AI工具集，无需上传到服务器，安全快速
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 max-w-4xl mx-auto">
      <!-- 图片压缩 -->
      <a href="/tools/compress" class="group rounded-2xl border border-neutral-200 bg-white/80 p-6 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/40">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-blue-50 text-2xl dark:bg-blue-950">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-blue-600 dark:text-blue-400"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200 group-hover:text-primary dark:group-hover:text-primary-light transition-colors" data-i18n="tool-card-compress-title">图片压缩</h3>
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400" data-i18n="tool-card-compress-desc">智能压缩引擎，自动优化图片体积。支持 JPG / PNG / WebP 格式</p>
          </div>
        </div>
      </a>

      <!-- 格式转换 -->
      <a href="/tools/convert" class="group rounded-2xl border border-neutral-200 bg-white/80 p-6 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/40">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-green-50 text-2xl dark:bg-green-950">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-green-600 dark:text-green-400"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200 group-hover:text-primary dark:group-hover:text-primary-light transition-colors" data-i18n="tool-card-convert-title">格式转换</h3>
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400" data-i18n="tool-card-convert-desc">支持 JPG / PNG / WebP / BMP 格式互转，纯浏览器端处理</p>
          </div>
        </div>
      </a>

      <!-- 尺寸调整 -->
      <a href="/tools/resize" class="group rounded-2xl border border-neutral-200 bg-white/80 p-6 transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5 dark:border-neutral-700 dark:bg-neutral-900/80 dark:hover:border-primary/40">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-purple-50 text-2xl dark:bg-purple-950">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-purple-600 dark:text-purple-400"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200 group-hover:text-primary dark:group-hover:text-primary-light transition-colors" data-i18n="tool-card-resize-title">尺寸调整</h3>
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400" data-i18n="tool-card-resize-desc">批量调整图片尺寸，支持 4K / 2K / 1080p 等常见尺寸预设</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</Layout>
