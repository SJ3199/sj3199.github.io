---
import Layout from "@/layouts/Layout.astro";
import aiTools from "@/collections/ai-tools.json";

const currentPath = "/ai-tools";
---

<Layout pageTitle="AI工具推荐" pageDescription="SAMAI AI工具推荐导航，精选AI对话、图像、编程、视频、办公、音频工具" currentPath={currentPath}>

<div class="min-h-screen bg-neutral-50 dark:bg-neutral-950">
  <!-- Hero / Search Section -->
  <section class="pt-28 pb-12 sm:pt-36 sm:pb-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-neutral-900 dark:text-white mb-3">
        🚀 AI工具推荐
      </h1>
      <p class="text-neutral-500 dark:text-neutral-400 mb-8 text-sm sm:text-base">
        精选优质AI工具，覆盖对话、图像、编程、视频、办公、音频等领域
      </p>

      <!-- Search Box -->
      <div class="relative max-w-xl mx-auto mb-6" id="searchContainer">
        <div class="flex items-center gap-2 p-1.5 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-xl shadow-sm hover:shadow-md transition-shadow">
          <svg class="w-5 h-5 ml-3 text-neutral-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            id="toolSearch"
            type="text"
            placeholder="搜索AI工具..."
            class="flex-1 bg-transparent border-none outline-none text-sm py-2 text-neutral-800 dark:text-neutral-200 placeholder:text-neutral-400"
          />
          <div class="flex items-center gap-1">
            <button class="search-engine-btn active px-2.5 py-1 text-xs rounded-md bg-primary/10 text-primary font-medium" data-engine="all">全部</button>
            <button class="search-engine-btn px-2.5 py-1 text-xs rounded-md text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors" data-engine="baidu">百度</button>
            <button class="search-engine-btn px-2.5 py-1 text-xs rounded-md text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors" data-engine="ai-search">AI搜索</button>
          </div>
        </div>
        <!-- Search results hint -->
        <div id="searchHint" class="hidden mt-2 text-xs text-neutral-400">
          按回车键跳到外部搜索: <span id="searchEngineName">百度</span>
        </div>
      </div>

      <!-- External search engine links -->
      <div class="flex flex-wrap items-center justify-center gap-2 text-xs text-neutral-400 mt-3">
        <span class="text-neutral-500">站外搜索:</span>
        <a href="https://www.baidu.com/s?wd=" target="_blank" rel="noopener" class="search-link hover:text-blue-500 transition-colors" data-query>百度</a>
        <span class="text-neutral-300">|</span>
        <a href="https://www.google.com/search?q=" target="_blank" rel="noopener" class="search-link hover:text-blue-500 transition-colors" data-query>Google</a>
        <span class="text-neutral-300">|</span>
        <a href="https://kaifa.baidu.com/searchPage?wd=" target="_blank" rel="noopener" class="search-link hover:text-blue-500 transition-colors" data-query>AI搜索</a>
      </div>
    </div>
  </section>

  <!-- Category Tabs -->
  <section class="sticky top-[72px] sm:top-[84px] z-30 bg-neutral-50/95 dark:bg-neutral-950/95 backdrop-blur-sm border-b border-neutral-200 dark:border-neutral-800">
    <div class="max-w-6xl mx-auto px-4 py-3 overflow-x-auto scrollbar-hide">
      <div class="flex items-center justify-center gap-1 sm:gap-2 min-w-max">
        <button class="category-btn active px-3 sm:px-4 py-1.5 text-sm rounded-full font-medium transition-all duration-200 bg-primary text-white shadow-sm" data-cat="all">
          全部
        </button>
        {aiTools.map((cat) => (
          <button class="category-btn px-3 sm:px-4 py-1.5 text-sm rounded-full font-medium transition-all duration-200 bg-neutral-200 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-300 dark:hover:bg-neutral-700" data-cat={cat.id}>
            {cat.nameZh}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Tool Cards Grid -->
  <section class="max-w-6xl mx-auto px-4 py-8 sm:py-12">
    <div id="toolsGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
      {aiTools.map((cat) => (
        cat.tools.map((tool) => (
          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            data-category={cat.id}
            data-name={tool.name.toLowerCase()}
            data-name-zh={tool.nameZh || tool.name}
            data-desc={tool.descZh || tool.desc}
            class="tool-card group flex flex-col items-center justify-center p-4 sm:p-5 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-xl hover:border-primary/30 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
          >
            <span class="text-3xl sm:text-4xl mb-2">{tool.icon}</span>
            <span class="font-semibold text-sm text-neutral-800 dark:text-neutral-200 text-center group-hover:text-primary transition-colors">{tool.name}</span>
            <span class="text-xs text-neutral-400 dark:text-neutral-500 text-center mt-1 leading-tight">{tool.descZh}</span>
          </a>
        ))
      ))}
    </div>

    <!-- No Results -->
    <div id="noResults" class="hidden text-center py-16 text-neutral-400">
      <p class="text-lg">没有找到匹配的工具</p>
      <p class="text-sm mt-2">试试其他关键词或使用站外搜索</p>
    </div>
  </section>
</div>

</Layout>

<script>
  // Category filtering
  const categoryBtns = document.querySelectorAll('.category-btn');
  const toolCards = document.querySelectorAll('.tool-card');
  const noResults = document.getElementById('noResults')!;
  const toolsGrid = document.getElementById('toolsGrid')!;
  const searchInput = document.getElementById('toolSearch') as HTMLInputElement;

  let activeCategory = 'all';

  function updateActiveBtn(activeBtn: Element) {
    categoryBtns.forEach(b => {
      b.classList.remove('active', 'bg-primary', 'text-white', 'shadow-sm');
      b.classList.add('bg-neutral-200', 'dark:bg-neutral-800', 'text-neutral-600', 'dark:text-neutral-400');
    });
    activeBtn.classList.remove('bg-neutral-200', 'dark:bg-neutral-800', 'text-neutral-600', 'dark:text-neutral-400');
    activeBtn.classList.add('active', 'bg-primary', 'text-white', 'shadow-sm');
  }

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      updateActiveBtn(btn);
      activeCategory = (btn as HTMLElement).dataset.cat || 'all';
      filterTools();
    });
  });

  function filterTools() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    toolCards.forEach(card => {
      const el = card as HTMLElement;
      const cat = el.dataset.category;
      const name = el.dataset.name || '';
      const nameZh = el.dataset['nameZh'] || '';
      const desc = el.dataset.desc || '';

      const catMatch = activeCategory === 'all' || cat === activeCategory;
      const searchMatch = !query ||
        name.includes(query) ||
        nameZh.includes(query) ||
        desc.includes(query);

      if (catMatch && searchMatch) {
        el.style.display = '';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (visibleCount === 0) {
      noResults.style.display = 'block';
      toolsGrid.style.display = 'none';
    } else {
      noResults.style.display = 'none';
      toolsGrid.style.display = '';
    }
  }

  // Search engine toggle
  const engineBtns = document.querySelectorAll('.search-engine-btn');
  const searchHint = document.getElementById('searchHint')!;
  const searchEngineName = document.getElementById('searchEngineName')!;
  const searchLinks = document.querySelectorAll('.search-link');

  let activeEngine = 'all';

  engineBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      engineBtns.forEach(b => {
        b.classList.remove('active', 'bg-primary/10', 'text-primary', 'font-medium');
        b.classList.add('text-neutral-500');
      });
      btn.classList.add('active', 'bg-primary/10', 'text-primary', 'font-medium');
      btn.classList.remove('text-neutral-500');
      activeEngine = (btn as HTMLElement).dataset.engine || 'all';
      searchInput.focus();
      updateSearchLinks();
    });
  });

  function updateSearchLinks() {
    const query = encodeURIComponent(searchInput.value.trim());
    const engineNames: Record<string, string> = { baidu: '百度', 'ai-search': '百度AI搜索' };
    searchEngineName.textContent = engineNames[activeEngine] || '百度';

    if (activeEngine === 'all') {
      searchHint.classList.add('hidden');
    } else {
      searchHint.classList.remove('hidden');
    }
    searchLinks.forEach(link => {
      (link as HTMLAnchorElement).dataset.query = query;
    });
  }

  // Real-time search filtering
  searchInput.addEventListener('input', () => {
    filterTools();
    updateSearchLinks();
  });

  // Enter to open external search
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && activeEngine !== 'all') {
      const query = encodeURIComponent(searchInput.value.trim());
      if (!query) return;
      let url = '';
      if (activeEngine === 'baidu') url = `https://www.baidu.com/s?wd=${query}`;
      else if (activeEngine === 'ai-search') url = `https://kaifa.baidu.com/searchPage?wd=${query}`;
      if (url) window.open(url, '_blank');
    }
  });

  // External search links
  searchLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      const query = searchInput.value.trim();
      if (!query) {
        e.preventDefault();
        searchInput.focus();
      } else {
        const a = link as HTMLAnchorElement;
        a.href = a.dataset.baseHref + encodeURIComponent(query);
      }
    });
  });

  // Set base hrefs for external search links
  const baseUrls: Record<string, string> = {
    '百度': 'https://www.baidu.com/s?wd=',
    'Google': 'https://www.google.com/search?q=',
    'AI搜索': 'https://kaifa.baidu.com/searchPage?wd=',
  };
  searchLinks.forEach(link => {
    const a = link as HTMLAnchorElement;
    const text = a.textContent?.trim() || '';
    if (baseUrls[text]) {
      a.dataset.baseHref = baseUrls[text];
    }
  });

  // Initialize search links
  searchInput.dispatchEvent(new Event('input'));
</script>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
