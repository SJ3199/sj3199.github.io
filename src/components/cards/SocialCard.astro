---
import social from "@/collections/social.json";
const { displaySocialIds } = Astro.props;

const filteredSocial = displaySocialIds.length > 0
  ? displaySocialIds.map(id => social.find(item => item.id === id && item.isShow !== false)).filter(Boolean)
  : social.filter(item => item.isShow !== false);
---

<div class="social-cards-wrapper">
  <div class="social-list">
    {filteredSocial.map((item, index) => (
      <div class="social-item-outer" style={`--i: ${index}; --t: ${filteredSocial.length};`}>
        {item.name === "WeChat" ? (
          <div class="social-item qr-trigger" data-copy="SJ664487637" data-i18n-label="label-wechat-id">
            <img src={item.image} alt={item.name} class="social-image" />
            <div class="qr-popup">
              <img src="/assets/social/wechat-qr.png" alt="微信二维码" data-i18n-alt="qr-alt-wechat" class="qr-img" />
            </div>
          </div>
        ) : item.name === "抖音" ? (
          <div class="social-item qr-trigger" data-copy="96105575" data-i18n-label="label-douyin-id">
            <img src={item.image} alt={item.name} class="social-image" />
            <div class="qr-popup">
              <img src="/assets/social/douyin-qr.png" alt="抖音二维码" data-i18n-alt="qr-alt-douyin" class="qr-img" />
            </div>
          </div>
        ) : (
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="social-item">
            <img src={item.image} alt={item.name} class="social-image" />
          </a>
        )}
      </div>
    ))}
  </div>
  <!-- Toast for copy feedback -->
  <div id="copy-toast" class="copy-toast"></div>
</div>

<style>
  .social-cards-wrapper { width: 100%; position: relative; }
  .social-list {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .social-list {
      justify-content: center;
    }
  }
  .social-item-outer {
    flex-shrink: 0;
    position: relative;
  }
  .social-item {
    flex-shrink: 0;
    border-radius: 0.75rem;
    cursor: pointer;
    width: 56px;
    height: 56px;
    display: block;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: visible;
    border: none;
    padding: 0;
    background: none;
  }
  .social-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  .social-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
  }

  /* QR popup: shown BELOW on hover (desktop only) */
  .qr-popup {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
    z-index: 1000;
    background: #fff;
    border-radius: 12px;
    border: none;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    padding: 8px;
    line-height: 0;
  }
  /* Arrow pointing up */
  .qr-popup::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-bottom-color: #fff;
  }
  /* Desktop: show on hover */
  @media (hover: hover) and (pointer: fine) {
    .qr-trigger:hover .qr-popup {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }
  /* Narrow viewports: hide QR popup, use click-to-copy */
  @media (max-width: 767px) {
    .qr-popup { display: none !important; }
  }
  /* Mobile: never show QR popup */
  @media (hover: none), (pointer: coarse) {
    .qr-popup {
      display: none;
    }
  }
  .qr-img {
    max-width: 200px;
    max-height: 200px;
    width: auto;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  /* Toast styles */
  .copy-toast {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    padding: 12px 28px;
    border-radius: 2rem;
    font-size: 15px;
    font-family: 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 99999;
    white-space: nowrap;
  }
  .copy-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  document.querySelectorAll('.qr-trigger').forEach((trigger) => {
    const el = trigger as HTMLElement;
    const copyId = el.dataset.copy || '';
    const labelKey = el.dataset.i18nLabel || '';

    // Click → copy to clipboard (both desktop & mobile)
    el.addEventListener('click', async (e) => {
      e.preventDefault();
      try {
        await navigator.clipboard.writeText(copyId);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = copyId;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const toast = document.getElementById('copy-toast');
      if (toast) {
        toast.textContent = (window.t ? window.t('toast-copied') : '已复制') + ' ' + (labelKey && window.t ? window.t(labelKey) : 'WeChat') + ': ' + copyId;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2000);
      }
    });
  });
</script>
