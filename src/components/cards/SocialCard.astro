---
import social from "@/collections/social.json";
const { displaySocialIds } = Astro.props;

const filteredSocial = displaySocialIds.length > 0
  ? displaySocialIds.map(id => social.find(item => item.id === id && item.isShow !== false)).filter(Boolean)
  : social.filter(item => item.isShow !== false);
---

<div class="social-cards-wrapper">
  <div class="social-list">
    {filteredSocial.map((item, index) => (
      <div class="social-item-outer" style={`--i: ${index}; --t: ${filteredSocial.length};`}>
        {item.name === "WeChat" ? (
          <>
            <button class="social-item qr-trigger" data-popup="wechat-qr-popup" data-copy="SJ664487637" data-label="微信号">
              <img src={item.image} alt={item.name} class="social-image" />
            </button>
            <div id="wechat-qr-popup" class="qr-card" popover>
              <img src="/portfolio/assets/social/wechat-qr.png" alt="微信二维码" class="qr-img" />
            </div>
          </>
        ) : item.name === "抖音" ? (
          <>
            <button class="social-item qr-trigger" data-popup="douyin-qr-popup" data-copy="96105575" data-label="抖音ID">
              <img src={item.image} alt={item.name} class="social-image" />
            </button>
            <div id="douyin-qr-popup" class="qr-card" popover>
              <img src="/portfolio/assets/social/douyin-qr.png" alt="抖音二维码" class="qr-img" />
            </div>
          </>
        ) : (
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="social-item">
            <img src={item.image} alt={item.name} class="social-image" />
          </a>
        )}
      </div>
    ))}
  </div>
  <!-- Toast for mobile copy -->
  <div id="copy-toast" class="copy-toast"></div>
</div>

<style>
  .social-cards-wrapper { width: 100%; position: relative; }
  .social-list {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .social-list {
      justify-content: center;
    }
  }
  .social-item-outer {
    flex-shrink: 0;
    position: relative;
  }
  .social-item {
    flex-shrink: 0;
    border-radius: 0.75rem;
    cursor: pointer;
    width: 56px;
    height: 56px;
    display: block;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
    border: none;
    padding: 0;
    background: none;
  }
  .social-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  .social-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
  }

  .qr-card {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 1rem;
  }
  .qr-card::backdrop {
    background: transparent;
  }
  .qr-img {
    max-width: 220px;
    max-height: 220px;
    width: auto;
    height: auto;
    display: block;
    border-radius: 0.5rem;
  }

  /* Toast styles */
  .copy-toast {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    padding: 12px 28px;
    border-radius: 2rem;
    font-size: 15px;
    font-family: 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 99999;
    white-space: nowrap;
  }
  .copy-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  const isMobile = 'ontouchstart' in window || window.innerWidth <= 640;

  document.querySelectorAll('.qr-trigger').forEach((trigger) => {
    const el = trigger as HTMLElement;
    const popupId = el.dataset.popup;
    const copyId = el.dataset.copy;
    const label = el.dataset.label;

    if (isMobile && copyId) {
      // Mobile: copy to clipboard + toast
      el.addEventListener('click', async (e) => {
        e.preventDefault();
        try {
          await navigator.clipboard.writeText(copyId);
        } catch {
          // Fallback for older browsers
          const ta = document.createElement('textarea');
          ta.value = copyId;
          ta.style.position = 'fixed';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        const toast = document.getElementById('copy-toast');
        if (toast) {
          toast.textContent = '已复制' + label + ' ' + copyId;
          toast.classList.add('show');
          setTimeout(() => toast.classList.remove('show'), 2000);
        }
      });
      return; // Skip desktop popover setup
    }

    if (!popupId) return;
    const popup = document.getElementById(popupId);
    if (!popup) return;

    function positionPopup() {
      const rect = el.getBoundingClientRect();
      (popup as HTMLElement).style.left = rect.left + 'px';
      (popup as HTMLElement).style.top = (rect.bottom + 12) + 'px';
    }
    el.addEventListener('click', () => {
      if (popup.matches(':popover-open')) {
        positionPopup();
      }
    });
    el.addEventListener('mouseenter', () => {
      if (!popup.matches(':popover-open')) popup.showPopover();
      positionPopup();
    });
    el.addEventListener('mouseleave', () => {
      popup.hidePopover();
    });
    popup.addEventListener('mouseenter', () => {});
    popup.addEventListener('mouseleave', () => {
      popup.hidePopover();
    });
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t.closest(`[data-popup="${popupId}"]`) && !t.closest(`#${popupId}`)) {
        popup.hidePopover();
      }
    });
  });
</script>
