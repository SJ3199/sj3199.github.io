        </button>
        <div id="footer-wechat-qr" class="qr-card footer-qr-card" popover>
          <img src="/assets/social/wechat-qr.png" alt="微信二维码" class="qr-img" />
        </div>
      </span>
      <span class="footer-icon text-neutral-800 dark:text-[#ff0050]" title="抖音" data-i18n-title="social-douyin">
        <button class="footer-qr-trigger" data-popup="footer-douyin-qr" data-copy="96105575" data-label="抖音ID">
          <svg class="footer-social-img" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </button>
        <div id="footer-douyin-qr" class="qr-card footer-qr-card" popover>
          <img src="/assets/social/douyin-qr.png" alt="抖音二维码" class="qr-img" />
        </div>
      </span>
    </span>

  </div>
</section>

<ToTop />

<style>
  .footer-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }
  .footer-icon:hover {
    opacity: 1;
  }
  .footer-social-img {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    object-fit: cover;
  }
  .footer-qr-trigger {
    cursor: pointer;
    border: none;
    padding: 0;
    background: none;
    display: flex;
    align-items: center;
  }
  .qr-card {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 1rem;
  }
  .qr-card::backdrop { background: transparent; }
  .qr-img {
    max-width: 220px;
    max-height: 220px;
    width: auto;
    height: auto;
    display: block;
    border-radius: 0.5rem;
  }
</style>

<script>
  const footerIsMobile = 'ontouchstart' in window || window.innerWidth <= 640;

  document.querySelectorAll('.footer-qr-trigger').forEach((trigger) => {
    const el = trigger as HTMLElement;
    const popupId = el.dataset.popup;
    const copyId = el.dataset.copy;
    const label = el.dataset.label;

    if (footerIsMobile && copyId) {
      el.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        try {
          await navigator.clipboard.writeText(copyId);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = copyId;
          ta.style.position = 'fixed';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        let toast = document.getElementById('footer-copy-toast');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'footer-copy-toast';
          toast.style.cssText = 'position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);background:rgba(0,0,0,0.85);color:#fff;padding:12px 28px;border-radius:2rem;font-size:15px;font-family:"PingFang SC","Microsoft YaHei","Noto Sans SC",sans-serif;opacity:0;pointer-events:none;transition:opacity 0.3s ease,transform 0.3s ease;z-index:99999;white-space:nowrap;';
          document.body.appendChild(toast);
        }
        toast.textContent = '已复制' + label + ' ' + copyId;
        toast.style.opacity = '1';
        toast.style.transform = 'translateX(-50%) translateY(0)';
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(-50%) translateY(20px)';
        }, 2000);
      });
      return;
    }

    if (!popupId) return;
    const popup = document.getElementById(popupId);
    if (!popup) return;

    function positionPopup() {
      const rect = el.getBoundingClientRect();
      (popup as HTMLElement).style.left = (rect.left + rect.width / 2) + 'px';
      (popup as HTMLElement).style.top = (rect.top - 10) + 'px';
      (popup as HTMLElement).style.transform = 'translate(-50%, -100%)';
    }
    el.addEventListener('click', () => {
      if (popup.matches(':popover-open')) positionPopup();
    });
    el.addEventListener('mouseenter', () => {
      if (!popup.matches(':popover-open')) popup.showPopover();
      positionPopup();
    });
    el.addEventListener('mouseleave', () => popup.hidePopover());
    popup.addEventListener('mouseenter', () => {});
    popup.addEventListener('mouseleave', () => popup.hidePopover());
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t.closest(`[data-popup="${popupId}"]`) && !t.closest(`#${popupId}`)) {
        popup.hidePopover();
      }
    });
  });
</script>