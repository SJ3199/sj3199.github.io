---
import ToTop from "@/components/widgets/ToTop.astro";
---

<section class="text-gray-700 border-t mt-20 md:mt-48 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="flex flex-col sm:flex-row items-center justify-between py-8 mx-auto px-7 max-w-7xl gap-4">

    <p class="text-sm text-neutral-700 dark:text-neutral-100 text-center sm:text-left">
      © 2026 MajorSam
    </p>

    <span class="inline-flex items-center gap-5">
      <span class="footer-icon text-neutral-500 dark:text-neutral-300" title="GitHub" data-i18n-title="social-github">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
      </span>
      <span class="footer-icon" title="抖音" data-i18n-title="social-douyin">
        <button class="footer-qr-trigger" data-popup="footer-douyin-qr" data-copy="96105575" data-label="抖音ID">
          <img src="/portfolio/assets/social/social-douyin.png" alt="抖音" class="footer-social-img" />
        </button>
        <div id="footer-douyin-qr" class="qr-card footer-qr-card" popover>
          <img src="/portfolio/assets/social/douyin-qr.png" alt="抖音二维码" class="qr-img" />
        </div>
      </span>
      <span class="footer-icon" title="微信" data-i18n-title="social-wechat">
        <button class="footer-qr-trigger" data-popup="footer-wechat-qr" data-copy="SJ664487637" data-label="微信号">
          <img src="/portfolio/assets/social/social-wechat.png" alt="微信" class="footer-social-img" />
        </button>
        <div id="footer-wechat-qr" class="qr-card footer-qr-card" popover>
          <img src="/portfolio/assets/social/wechat-qr.png" alt="微信二维码" class="qr-img" />
        </div>
      </span>
    </span>

  </div>
</section>

<ToTop />

<style>
  .footer-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }
  .footer-icon:hover {
    opacity: 1;
  }
  .footer-social-img {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    object-fit: cover;
  }
  .footer-qr-trigger {
    cursor: pointer;
    border: none;
    padding: 0;
    background: none;
    display: flex;
    align-items: center;
  }
  .qr-card {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 1rem;
  }
  .qr-card::backdrop { background: transparent; }
  .qr-img {
    max-width: 220px;
    max-height: 220px;
    width: auto;
    height: auto;
    display: block;
    border-radius: 0.5rem;
  }
</style>

<script>
  const footerIsMobile = 'ontouchstart' in window || window.innerWidth <= 640;

  document.querySelectorAll('.footer-qr-trigger').forEach((trigger) => {
    const el = trigger as HTMLElement;
    const popupId = el.dataset.popup;
    const copyId = el.dataset.copy;
    const label = el.dataset.label;

    if (footerIsMobile && copyId) {
      el.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        try {
          await navigator.clipboard.writeText(copyId);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = copyId;
          ta.style.position = 'fixed';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        let toast = document.getElementById('footer-copy-toast');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'footer-copy-toast';
          toast.style.cssText = 'position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);background:rgba(0,0,0,0.85);color:#fff;padding:12px 28px;border-radius:2rem;font-size:15px;font-family:"PingFang SC","Microsoft YaHei","Noto Sans SC",sans-serif;opacity:0;pointer-events:none;transition:opacity 0.3s ease,transform 0.3s ease;z-index:99999;white-space:nowrap;';
          document.body.appendChild(toast);
        }
        toast.textContent = '已复制' + label + ' ' + copyId;
        toast.style.opacity = '1';
        toast.style.transform = 'translateX(-50%) translateY(0)';
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(-50%) translateY(20px)';
        }, 2000);
      });
      return;
    }

    if (!popupId) return;
    const popup = document.getElementById(popupId);
    if (!popup) return;

    function positionPopup() {
      const rect = el.getBoundingClientRect();
      (popup as HTMLElement).style.left = (rect.left + rect.width / 2) + 'px';
      (popup as HTMLElement).style.top = (rect.top - 10) + 'px';
      (popup as HTMLElement).style.transform = 'translate(-50%, -100%)';
    }
    el.addEventListener('click', () => {
      if (popup.matches(':popover-open')) positionPopup();
    });
    el.addEventListener('mouseenter', () => {
      if (!popup.matches(':popover-open')) popup.showPopover();
      positionPopup();
    });
    el.addEventListener('mouseleave', () => popup.hidePopover());
    popup.addEventListener('mouseenter', () => {});
    popup.addEventListener('mouseleave', () => popup.hidePopover());
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t.closest(`[data-popup="${popupId}"]`) && !t.closest(`#${popupId}`)) {
        popup.hidePopover();
      }
    });
  });
</script>