---

<section class="text-gray-700 border-t mt-auto border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="flex flex-col sm:flex-row items-center justify-between py-8 mx-auto px-7 max-w-7xl gap-4">

    <p class="text-sm text-neutral-700 dark:text-neutral-100 text-center sm:text-left">
      © 2026 MajorSam
    </p>

    <span class="inline-flex items-center gap-5">
      <span class="footer-icon text-neutral-500 dark:text-neutral-300" title="GitHub" data-i18n-title="social-github">
