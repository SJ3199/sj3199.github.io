---
import galleryItems from "@/collections/gallery.json";
import SectionHeader from "@/components/elements/SectionHeader.astro";

const categoryMap: Record<string, string> = {
  "live-stream": "直播画面",
  "posters": "海报设计",
  "detail-pages": "长图",
  "material-design": "物料设计",
  "brand-design": "品牌设计",
  "douyin-store": "抖音店铺",
  "douyin-products": "抖音产品图",
};

const categories = Object.keys(categoryMap);
const firstActiveCat = categories.find(cat => galleryItems.some(item => item.category === cat)) || categories[0];

// Group items by category
const itemsByCategory: Record<string, typeof galleryItems> = {};
for (const cat of categories) {
  itemsByCategory[cat] = galleryItems.filter(item => item.category === cat);
}

// Flatten for data-index reference (used by detail modal)
let globalIndex = 0;
const itemGlobalIndex: Map<any, number> = new Map();
for (const item of galleryItems) { itemGlobalIndex.set(item, globalIndex++); }

// --- Preload image list (first 3 images per category + all posters images) ---
const preloadImages: string[] = [];
for (const cat of categories) {
  const items = itemsByCategory[cat] || [];
  for (let i = 0; i < Math.min(6, items.length); i++) {
    preloadImages.push(items[i].image);
  }
}
// Deduplicate (shouldn't happen but just in case)
const uniquePreload = [...new Set(preloadImages)];
---

<!-- Preload critical images so columns 2/3 images load fast -->
{uniquePreload.map((src) => (
  <link rel="preload" as="image" href={src} />
))}

<section class="py-16 md:py-16 md:pb-12" id="gallery">
  <div class="site-container space-y-6 md:space-y-8">
    <SectionHeader
      title="作品集 ↓"
      description="以下是我的设计作品展示，点击进入详情。"
      i18nTitle="gallery-title"
      i18nDesc="gallery-desc"
    />

    <!-- Filter Tabs -->
    <div class="filter-wrapper" data-aos="fade-up-sm" data-aos-duration="600" data-aos-once="true">
      <div class="filter-list flex flex-wrap gap-3 justify-center">
        {categories.map((cat) => (
          <button class={`filter-tag${cat === firstActiveCat ? ' active' : ''}`} data-filter={cat} data-i18n-cat={cat}>
            {categoryMap[cat] || cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Per-category sections: ALL rendered in DOM, shown/hidden by filter -->
    <div id="galleryContainer">
      {categories.filter(cat => cat !== 'brand-design').map((cat) => {
        const items = itemsByCategory[cat] || [];
        return (
          <div class="gallery-category" data-cat={cat} id={`cat-${cat}`}>
            <div class="gallery-masonry" data-items={items.length}>
              {items.map((item) => (
                <article
                  class="gallery-item group cursor-pointer"
                  data-category={cat}
                  data-global={itemGlobalIndex.get(item)}
                >
                  <div class={`relative overflow-hidden rounded-2xl gallery-img-wrap${item.image.endsWith('.png') ? '' : ' border border-primary/10 dark:border-primary/20 bg-neutral-100 dark:bg-neutral-800'}`}>
                    <img
                      src={item.image}
                      alt={item.title}
                      class="w-full h-auto block"
                      width="600"
                      height="400"
                      decoding="async"
                      fetchpriority="auto"
                      onerror="this.style.display='none';this.parentElement.insertAdjacentHTML('beforeend','<div class=\'flex items-center justify-center bg-neutral-100 dark:bg-neutral-800\' style=\'min-height:200px\'><span class=\'text-neutral-400 text-sm\'>图片加载失败</span></div>')"
                    />
                  </div>
                </article>
              ))}
            </div>
          </div>
        );
      })}

      <!-- Brand Design: special layout -->
      {itemsByCategory['brand-design']?.length > 0 && (
        <div class="gallery-category" data-cat="brand-design" id="cat-brand-design">
          <div class="brand-grid flex flex-col md:flex-row gap-4 md:gap-6">
            <div class="brand-main w-full md:w-1/2 flex-shrink-0">
              <article class="gallery-item group cursor-pointer" data-category="brand-design" data-global={itemGlobalIndex.get(itemsByCategory['brand-design'][0])}>
                <div class={`relative overflow-hidden rounded-2xl gallery-img-wrap${itemsByCategory['brand-design'][0].image.endsWith('.png') ? '' : ' border border-primary/10 dark:border-primary/20 bg-neutral-100 dark:bg-neutral-800'}`}>
                  <img src={itemsByCategory['brand-design'][0].image} alt={itemsByCategory['brand-design'][0].title} class="w-full h-auto block" width="720" height="480" decoding="async" fetchpriority="auto" />
                </div>
              </article>
            </div>
            {itemsByCategory['brand-design'].length > 1 && (
              <div class="brand-rest flex-1 grid grid-cols-2 gap-4 md:gap-6 content-start">
                {itemsByCategory['brand-design'].slice(1).map((item) => (
                  <article class="gallery-item group cursor-pointer" data-category="brand-design" data-global={itemGlobalIndex.get(item)}>
                    <div class={`relative overflow-hidden rounded-2xl gallery-img-wrap${item.image.endsWith('.png') ? '' : ' border border-primary/10 dark:border-primary/20 bg-neutral-100 dark:bg-neutral-800'}`}>
                      <img src={item.image} alt={item.title} class="w-full h-auto block" width="480" height="360" decoding="async" fetchpriority="auto" />
                    </div>
                  </article>
                ))}
              </div>
            )}
          </div>
        </div>
      )}
    </div>

    <div id="galleryEmpty" class="hidden text-center py-20">
      <div class="text-6xl mb-4">📁</div>
      <p class="text-neutral-500 dark:text-neutral-400 text-lg" data-i18n="gallery-empty">该分类暂无作品</p>
    </div>
  </div>
</section>

<!-- Detail Modal -->
<div id="detailModal" class="fixed inset-0 z-[100] hidden bg-black/96 backdrop-blur-sm flex-col">
  <div class="absolute top-0 left-0 right-0 z-50 flex items-center justify-between px-4 md:px-8 py-3 bg-gradient-to-b from-black/80 to-transparent">
    <span id="detailCounter" class="text-white/60 text-sm"></span>
    <button onclick="closeDetail()" class="w-8 h-8 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white/80 hover:text-white transition-all text-lg leading-none">✕</button>
  </div>
  <button id="detailPrev" class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-50 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white hover:scale-110 transition-all duration-200" title="上一张">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
  </button>
  <button id="detailNext" class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-50 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white hover:scale-110 transition-all duration-200" title="下一张">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
  </button>
  <div id="detailBody" class="flex flex-col md:flex-row w-full max-w-[1080px] mx-auto flex-1 min-h-0">
    <div id="detailImageArea" class="flex-1 min-h-0">
      <div class="flex items-start justify-center p-4 md:p-6 h-full">
        <img id="detailImg" class="w-full rounded-lg" src="" alt="" />
      </div>
    </div>
    <div class="w-full md:w-[340px] lg:w-[380px] bg-neutral-900/90 backdrop-blur-md border-l border-white/10 overflow-y-auto flex-shrink-0">
      <div class="p-5 md:p-7">
        <span id="detailCat" class="inline-flex items-center rounded-full bg-primary/30 px-3 py-1 text-xs font-medium text-primary-light border border-primary/30 mb-4"></span>
        <h2 id="detailTitle" class="text-2xl font-brand text-white mb-3"></h2>
        <p id="detailDesc" class="text-neutral-300 text-sm leading-relaxed mb-4"></p>
        <div class="border-t border-white/10 my-5"></div>
        <div id="detailFields" class="space-y-4"></div>
        <div id="detailContent" class="mt-5 text-neutral-400 text-sm leading-relaxed space-y-3 whitespace-pre-line"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .filter-tag {
    border-radius: 32px;
    background-color: #fff;
    padding: 10px 24px;
    font-size: 14px;
    border: 1px solid #d0d0d0;
    line-height: 1;
    letter-spacing: 0.25px;
    color: #101010;
    text-align: center;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.075, 0.82, 0.165, 1);
  }
  .filter-tag:hover { background-color: rgba(10, 10, 10, 0.08); }
  .filter-tag.active { font-weight: 500; background: #0a0a0a; color: #f4f3f0; }
  html.dark .filter-tag { background-color: #19191b; color: #d6d5d4; border: 1px solid #696765; }
  html.dark .filter-tag:hover { background-color: rgba(243, 244, 247, 0.08); }
  html.dark .filter-tag.active { background: #f4f3f0; color: #19191b; font-weight: 500; }

  /* Per-category container: all in DOM, only active one visible */
  .gallery-category { display: none; }
  .gallery-category.active { display: block; }

  /* CSS columns waterfall — items fill top→bottom, left→right */
  .gallery-masonry {
    column-count: 1;
    column-gap: 1rem;
  }
  @media (min-width: 640px) {
    .gallery-masonry { column-count: 2; column-gap: 1.5rem; }
  }
  @media (min-width: 1024px) {
    .gallery-masonry { column-count: 3; column-gap: 1.5rem; }
  }

  /* Break-inside to prevent items splitting across columns */
  .gallery-item {
    break-inside: avoid;
    margin-bottom: 1rem;
    animation: fadeInUp 0.5s ease forwards;
    animation-fill-mode: backwards;
  }
  @media (min-width: 640px) { .gallery-item { margin-bottom: 1.5rem; } }

  .gallery-img-wrap { box-shadow: 0 2px 8px rgba(0,0,0,0.06); }

  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  #detailModal.show { display: flex; }

  #detailModal .overflow-y-auto::-webkit-scrollbar { width: 6px; }
  #detailModal .overflow-y-auto::-webkit-scrollbar-track { background: transparent; }
  #detailModal .overflow-y-auto::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

  #detailImageArea.scroll-mode { overflow-y: auto; }
  #detailImageArea.scroll-mode > div { align-items: flex-start !important; height: auto; }
  #detailImageArea.scroll-mode img { max-height: none; width: 100%; }

  #detailImageArea.fit-mode { overflow-y: hidden; }
  #detailImageArea.fit-mode > div { align-items: center !important; height: 100%; }
  #detailImageArea.fit-mode img { max-height: 85vh; object-fit: contain; width: auto; max-width: 100%; }
</style>

<div id="galleryDataStore" data-json={JSON.stringify(galleryItems.map(item => ({...item, categoryName: categoryMap[item.category] || item.categoryName})))} style="display:none"></div>

<script>
  const galleryData = JSON.parse(document.getElementById('galleryDataStore').getAttribute('data-json'));
  let currentDetailIndex = -1;
  let currentFilter = document.querySelector('.filter-tag.active')?.dataset.filter || 'live-stream';
  let currentCols = 0;

  function reorderForColumns(items, cols) {
    const N = items.length;
    if (N === 0) return items;
    const baseRows = Math.floor(N / cols);
    const extra = N % cols;
    const colStarts = [0];
    for (let c = 0; c < cols - 1; c++) {
      colStarts.push(colStarts[c] + (c < extra ? baseRows + 1 : baseRows));
    }
    const indexed = items.map(function(item, i) {
      var col = i % cols;
      var row = Math.floor(i / cols);
      var visPos = colStarts[col] + row;
      return { item: item, visPos: visPos };
    });
    indexed.sort(function(a, b) { return a.visPos - b.visPos; });
    return indexed.map(function(x) { return x.item; });
  }

  var naturalOrder = new Map();

  function getColumnCount() {
    return window.innerWidth >= 1024 ? 3 : window.innerWidth >= 640 ? 2 : 1;
  }

  function applyColumnOrder(cols) {
    document.querySelectorAll('.gallery-masonry').forEach(function(container) {
      var items = Array.from(container.children);
      if (cols > 1) {
        reorderForColumns(items, cols).forEach(function(el) { container.appendChild(el); });
      } else {
        var natural = naturalOrder.get(container);
        if (natural) natural.forEach(function(el) { container.appendChild(el); });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.gallery-masonry').forEach(function(container) {
      naturalOrder.set(container, Array.from(container.children));
      Array.from(container.children).forEach(function(el, i) {
        el.style.animationDelay = (i % 20) * 0.03 + 's';
      });
    });

    currentCols = getColumnCount();
    applyColumnOrder(currentCols);

    var filterBtns = document.querySelectorAll('.filter-tag');
    var initialCat = document.getElementById('cat-' + currentFilter);
    if (initialCat) initialCat.classList.add('active');

    function applyFilter(filter) {
      currentFilter = filter;
      document.querySelectorAll('.gallery-category').forEach(function(el) {
        el.classList.toggle('active', el.dataset.cat === filter);
      });
      updateClickHandlers(filter);
    }

    function updateClickHandlers(filter) {
      document.querySelectorAll('.gallery-item').forEach(function(item) {
        item.onclick = null;
        if (item.dataset.category === 'live-stream') {
          item.onclick = onDetailClick;
          item.style.cursor = 'pointer';
        } else {
          item.style.cursor = 'default';
        }
      });
    }

    function onDetailClick(e) {
      openDetail(parseInt(e.currentTarget.dataset.global || '0'));
    }

    updateClickHandlers(currentFilter);

    filterBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        filterBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        applyFilter(btn.dataset.filter || '');
      });
    });

    document.getElementById('detailPrev')?.addEventListener('click', function(e) { e.stopPropagation(); navigateDetail(-1); });
    document.getElementById('detailNext')?.addEventListener('click', function(e) { e.stopPropagation(); navigateDetail(1); });
    document.getElementById('detailModal')?.addEventListener('click', closeDetail);

    document.addEventListener('keydown', function(e) {
      var modal = document.getElementById('detailModal');
      if (!modal || !modal.classList.contains('show')) return;
      if (e.key === 'Escape') closeDetail();
      if (e.key === 'ArrowLeft') navigateDetail(-1);
      if (e.key === 'ArrowRight') navigateDetail(1);
    });
  });

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      var newCols = getColumnCount();
      if (newCols !== currentCols) {
        currentCols = newCols;
        applyColumnOrder(currentCols);
      }
    }, 200);
  });

  function openDetail(index) {
    currentDetailIndex = index;
    const data = galleryData[index];
    if (!data) return;

    document.getElementById('detailImg').src = data.image;
    document.getElementById('detailTitle').textContent = data.title;
    document.getElementById('detailDesc').textContent = data.description;
    document.getElementById('detailCat').textContent = data.categoryName;
    document.getElementById('detailContent').textContent = data.details || '';
    document.getElementById('detailCounter').textContent = `${index + 1} / ${galleryData.length}`;

    document.getElementById('detailFields').innerHTML = [
      { label: '项目类型', value: data.categoryName },
      { label: '项目名称', value: data.title },
      { label: '项目描述', value: data.description },
    ].map(f => `<div><span class="text-xs text-neutral-500 uppercase tracking-wider">${f.label}</span><p class="text-sm text-neutral-200 mt-1">${f.value}</p></div>`).join('');

    document.getElementById('detailModal').classList.add('show');
    document.body.style.overflow = 'hidden';

    const imgArea = document.getElementById('detailImageArea');
    const body = document.getElementById('detailBody');
    if (data.category === 'detail-pages') {
      imgArea.classList.add('scroll-mode');
      imgArea.classList.remove('fit-mode');
      body.style.maxWidth = '1080px';
    } else {
      imgArea.classList.add('fit-mode');
      imgArea.classList.remove('scroll-mode');
      body.style.maxWidth = 'none';
    }

    updateArrows();
  }

  function navigateDetail(dir) {
    var activeCat = document.querySelector('.gallery-category.active');
    if (!activeCat) return;
    var visibleItems = Array.from(activeCat.querySelectorAll('.gallery-item'));
    var currentEl = visibleItems.find(function(el) { return parseInt(el.dataset.global || '0') === currentDetailIndex; });
    var pos = visibleItems.indexOf(currentEl);
    var newPos = pos + dir;
    if (newPos < 0 || newPos >= visibleItems.length) return;
    openDetail(parseInt(visibleItems[newPos].dataset.global || '0'));
  }

  function updateArrows() {
    var activeCat = document.querySelector('.gallery-category.active');
    if (!activeCat) return;
    var visibleItems = Array.from(activeCat.querySelectorAll('.gallery-item'));
    var currentEl = visibleItems.find(function(el) { return parseInt(el.dataset.global || '0') === currentDetailIndex; });
    var pos = visibleItems.indexOf(currentEl);
    document.getElementById('detailPrev').style.opacity = pos <= 0 ? '0.3' : '1';
    document.getElementById('detailNext').style.opacity = pos >= visibleItems.length - 1 ? '0.3' : '1';
  }

  function closeDetail() {
    document.getElementById('detailModal').classList.remove('show');
    document.body.style.overflow = '';
    currentDetailIndex = -1;
  }
  window.closeDetail = closeDetail;
</script>
